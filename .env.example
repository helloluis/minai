# ─── LLM ─────────────────────────────────────────────────────────────────────
# Alibaba Cloud DashScope — get yours at https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/minai

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3006

# Random secret for signing session cookies (generate with: openssl rand -hex 32)
COOKIE_SECRET=

# ─── Google OAuth + Calendar ─────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable: Google Calendar API, Google OAuth2 API
# Create OAuth 2.0 credentials (Web application)
# Add authorized redirect URI: http://localhost:3006/api/auth/google/callback (dev)
#                               https://yourdomain.com/api/auth/google/callback (prod)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3006/api/auth/google/callback

# ─── Celo / MiniPay Payments ─────────────────────────────────────────────────
# BIP39 mnemonic for HD wallet derivation — each user gets a unique deposit address
# Generate with: node -e "import('viem/accounts').then(m => console.log(m.generateMnemonic(m.english)))"
# WARNING: Back this up. Loss = loss of all uncollected user deposits.
WALLET_SEED=

# Celo RPC endpoint
# Testnet (Alfajores): https://alfajores-forno.celo-testnet.org
# Mainnet:             https://forno.celo.org
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org

# ─── Web Search ──────────────────────────────────────────────────────────────
# Brave Search API — https://api.search.brave.com (free tier: 2k queries/month)
BRAVE_API_KEY=

# ─── Classifier (optional) ───────────────────────────────────────────────────
# 'dashscope' (default) or 'ollama' (requires local Ollama install)
CLASSIFIER_PROVIDER=dashscope
# Set to 'true' to run both providers in parallel and log disagreements
CLASSIFIER_COMPARE=false
# Only needed if CLASSIFIER_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8B
